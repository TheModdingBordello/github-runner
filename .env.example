# Org URL (https://github.com/my-org) or repo URL (https://github.com/owner/repo)
GITHUB_URL=https://github.com/owner/repo

# PAT used to fetch registration/removal tokens.
# Scopes: `repo` for repo-level runners, `admin:org` for org-level runners.
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx

# Alternatively provide a pre-generated registration token instead of a PAT:
#RUNNER_TOKEN=

# Optional
#RUNNER_NAME=
RUNNER_LABELS=docker,linux
#RUNNER_GROUP=
#RUNNER_WORKDIR=/mnt/agent/workspace
#RUNNER_EPHEMERAL=true

# Reset /mnt/agent and scratch dirs to a pristine snapshot on container start
# (defaults to the value of RUNNER_EPHEMERAL)
#RUNNER_CLEAN_FS=true

# uid/gid the runner process runs as (default: 1000).
# The entrypoint remaps the in-container user before dropping privileges;
# access to a mounted docker socket is granted automatically.
#PUID=1000
#PGID=1000
